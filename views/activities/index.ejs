<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="page-content">
  <%- include('../partials/flash') %>

  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-list-task me-2 text-info"></i>Actividades</h1>
    <% if (currentUser.role === 'admin') { %>
    <a href="/activities/new" class="btn btn-primary">
      <i class="bi bi-plus-circle me-1"></i>Nueva actividad
    </a>
    <% } %>
  </div>

  <!-- Filters -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <form method="GET" class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
          <input type="text" name="q" class="form-control" placeholder="Buscar actividad..." value="<%= filters.q || '' %>">
        </div>
        <div class="col-6 col-md-3">
          <select name="program_id" class="form-select">
            <option value="">Todos los programas</option>
            <% programs.forEach(p => { %>
              <option value="<%= p.id %>" <%= filters.program_id == p.id ? 'selected' : '' %>>
                <%= p.name %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-3">
          <select name="level" class="form-select">
            <option value="">Todos los niveles</option>
            <% educationLevels.forEach(group => { %>
              <optgroup label="<%= group.stage %>">
                <% group.levels.forEach(lvl => { %>
                  <option value="<%= lvl %>" <%= filters.level === lvl ? 'selected' : '' %>><%= lvl %></option>
                <% }) %>
              </optgroup>
            <% }) %>
          </select>
        </div>
        <div class="col-12 col-md-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-search me-1"></i>Filtrar</button>
          <a href="/activities" class="btn btn-outline-secondary btn-sm">×</a>
        </div>
      </form>
    </div>
  </div>

  <!-- Active filters summary -->
  <% if (filters.program_id || filters.level || filters.q) { %>
  <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
    <span class="text-muted small">Filtrando por:</span>
    <% if (filters.q) { %>
      <span class="badge bg-secondary-subtle text-secondary border">
        "<%= filters.q %>"
        <a href="/activities?<%= filters.program_id ? 'program_id=' + filters.program_id + '&' : '' %><%= filters.level ? 'level=' + encodeURIComponent(filters.level) : '' %>" class="text-secondary ms-1">×</a>
      </span>
    <% } %>
    <% if (filters.program_id) { %>
      <% const fp = programs.find(p => p.id == filters.program_id); %>
      <% if (fp) { %>
      <span class="badge border" style="background:<%=fp.color%>20;color:<%=fp.color%>;border-color:<%=fp.color%>40!important">
        <i class="bi bi-<%=fp.icon%> me-1"></i><%= fp.name %>
        <a href="/activities?<%= filters.q ? 'q=' + encodeURIComponent(filters.q) + '&' : '' %><%= filters.level ? 'level=' + encodeURIComponent(filters.level) : '' %>" style="color:inherit" class="ms-1">×</a>
      </span>
      <% } %>
    <% } %>
    <% if (filters.level) { %>
      <span class="badge bg-info-subtle text-info border">
        <i class="bi bi-mortarboard me-1"></i><%= filters.level %>
        <a href="/activities?<%= filters.q ? 'q=' + encodeURIComponent(filters.q) + '&' : '' %><%= filters.program_id ? 'program_id=' + filters.program_id : '' %>" class="text-info ms-1">×</a>
      </span>
    <% } %>
    <span class="text-muted small ms-1"><%= activities.length %> resultado<%= activities.length !== 1 ? 's' : '' %></span>
  </div>
  <% } %>

  <!-- Program quick pills (unchanged) -->
  <div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/activities<%= filters.q ? '?q=' + encodeURIComponent(filters.q) : '' %>"
      class="btn btn-sm <%= !filters.program_id && !filters.level ? 'btn-secondary' : 'btn-outline-secondary' %>">
      Todos
    </a>
    <% programs.forEach(p => { %>
      <a href="/activities?program_id=<%= p.id %><%= filters.q ? '&q=' + encodeURIComponent(filters.q) : '' %><%= filters.level ? '&level=' + encodeURIComponent(filters.level) : '' %>"
        class="btn btn-sm <%= filters.program_id == p.id ? 'text-white' : 'btn-outline-secondary' %>"
        style="<%= filters.program_id == p.id ? 'background:' + p.color + '; border-color:' + p.color : '' %>">
        <i class="bi bi-<%= p.icon %> me-1"></i><%= p.name %>
      </a>
    <% }) %>
  </div>

  <% if (activities.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-list-x fs-1 opacity-50 mb-3 d-block"></i>
      <h3 class="h5">Sin actividades</h3>
      <% if (filters.program_id || filters.level || filters.q) { %>
        <p class="small">Prueba a quitar algún filtro.</p>
        <a href="/activities" class="btn btn-outline-secondary btn-sm">Quitar filtros</a>
      <% } else if (currentUser.role === 'admin') { %>
        <a href="/activities/new" class="btn btn-primary">Crear actividad</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% activities.forEach(a => { %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 activity-card" style="border-left: 4px solid <%= a.color %> !important">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="program-pill small" style="background: <%= a.color %>20; color: <%= a.color %>; border: 1px solid <%= a.color %>30">
                <i class="bi bi-<%= a.icon %> me-1"></i><%= a.program_name %>
              </span>
              <span class="badge bg-light text-muted border"><%= a.duration || 30 %> min</span>
            </div>
            <h3 class="h6 fw-semibold mb-1"><%= a.name %></h3>
            <% if (a.description) { %>
              <p class="text-muted small mb-2 line-clamp-2"><%= a.description %></p>
            <% } %>
            <% if (a.situation_title) { %>
              <div class="small text-muted mb-1"><i class="bi bi-map me-1"></i><%= a.situation_title %></div>
            <% } %>
            <% if (a.levels) { %>
              <div class="d-flex flex-wrap gap-1 mt-1">
                <% a.levels.split(',').forEach(lvl => { %>
                  <span class="badge bg-info-subtle text-info" style="font-size:.65rem"><%= lvl %></span>
                <% }) %>
              </div>
            <% } else { %>
              <span class="badge bg-light text-muted" style="font-size:.65rem">Todos los niveles</span>
            <% } %>
          </div>
          <% if (currentUser.role === 'admin') { %>
          <div class="card-footer bg-transparent border-0 pt-0 pb-2">
            <a href="/activities/<%= a.id %>/edit" class="btn btn-xs btn-outline-secondary">
              <i class="bi bi-pencil me-1"></i>Editar
            </a>
          </div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
