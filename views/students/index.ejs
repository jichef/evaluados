<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="page-content">
  <%- include('../partials/flash') %>

  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-people me-2 text-success"></i>Alumnado</h1>
    <% if (currentUser.role === 'admin') { %>
    <div class="d-flex gap-2">
      <a href="/students/import/excel" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-upload me-1"></i>Importar Excel
      </a>
      <a href="/students/new" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Nuevo alumno
      </a>
    </div>
    <% } %>
  </div>

  <!-- Filters -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2">
      <form method="GET" class="row g-2 align-items-end">
        <div class="col-12 col-md-5">
          <input type="text" name="q" class="form-control" placeholder="Buscar por nombre o apellidos..." value="<%= filters.q || '' %>">
        </div>
        <div class="col-6 col-md-2">
          <select name="course" class="form-select">
            <option value="">Todos los cursos</option>
            <% courses.forEach(c => { %>
              <option value="<%= c.course %>" <%= filters.course === c.course ? 'selected' : '' %>><%= c.course %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-2">
          <select name="group" class="form-select">
            <option value="">Todos los grupos</option>
            <% groups.forEach(g => { %>
              <option value="<%= g.group_name %>" <%= filters.group === g.group_name ? 'selected' : '' %>><%= g.group_name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12 col-md-3 d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-search me-1"></i>Buscar</button>
          <a href="/students" class="btn btn-outline-secondary btn-sm">Limpiar</a>
        </div>
      </form>
    </div>
  </div>

  <% if (students.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-person-x fs-1 opacity-50 mb-3 d-block"></i>
      <h3 class="h5">Sin alumnado</h3>
      <% if (currentUser.role === 'admin') { %>
        <p>Añade alumnado manualmente o importa desde Excel.</p>
        <a href="/students/new" class="btn btn-primary me-2">Nuevo alumno</a>
        <a href="/students/import/excel" class="btn btn-outline-secondary">Importar Excel</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent">
        <small class="text-muted"><%= students.length %> alumno<%= students.length !== 1 ? 's' : '' %></small>
      </div>
      <!-- Desktop table -->
      <div class="table-responsive d-none d-md-block">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Apellidos, Nombre</th>
              <th>Curso</th>
              <th>Grupo</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(s => { %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="student-avatar"><%= s.name.charAt(0) %><%= s.surname.charAt(0) %></div>
                  <a href="/students/<%= s.id %>" class="text-decoration-none fw-semibold">
                    <%= s.surname %>, <%= s.name %>
                  </a>
                </div>
              </td>
              <td><%= s.course || '—' %></td>
              <td><%= s.group_name || '—' %></td>
              <td class="text-end">
                <a href="/sessions/new?student_id=<%= s.id %>" class="btn btn-xs btn-primary me-1" title="Nueva sesión">
                  <i class="bi bi-plus-circle"></i>
                </a>
                <a href="/students/<%= s.id %>" class="btn btn-xs btn-outline-secondary me-1" title="Ver perfil">
                  <i class="bi bi-eye"></i>
                </a>
                <% if (currentUser.role === 'admin') { %>
                <a href="/students/<%= s.id %>/edit" class="btn btn-xs btn-outline-secondary" title="Editar">
                  <i class="bi bi-pencil"></i>
                </a>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile list -->
      <div class="d-md-none list-group list-group-flush">
        <% students.forEach(s => { %>
        <div class="list-group-item py-3">
          <div class="d-flex align-items-center gap-3">
            <div class="student-avatar"><%= s.name.charAt(0) %><%= s.surname.charAt(0) %></div>
            <div class="flex-grow-1">
              <a href="/students/<%= s.id %>" class="fw-semibold text-decoration-none d-block"><%= s.surname %>, <%= s.name %></a>
              <small class="text-muted"><%= s.course || '' %> <%= s.group_name ? '· ' + s.group_name : '' %></small>
            </div>
            <a href="/sessions/new?student_id=<%= s.id %>" class="btn btn-sm btn-primary">
              <i class="bi bi-plus"></i>
            </a>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
