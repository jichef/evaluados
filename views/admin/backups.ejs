<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="page-content">
  <%- include('../partials/flash') %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-3">
      <a href="/admin" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
      <h1 class="h3 fw-bold mb-0"><i class="bi bi-shield-check me-2 text-success"></i>Copias de Seguridad</h1>
    </div>
    <form method="POST" action="/admin/backups/create">
      <button type="submit" class="btn btn-success">
        <i class="bi bi-download me-2"></i>Crear copia ahora
      </button>
    </form>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm border-success-subtle">
        <div class="card-body">
          <h3 class="h6 fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-info"></i>Configuración actual</h3>
          <dl class="mb-0 small">
            <dt>Backup automático diario</dt>
            <dd class="text-muted"><%= settings.backup_time || '02:00' %> h</dd>
            <dt>Backup semanal</dt>
            <dd class="text-muted">Domingos 03:00 h</dd>
            <dt>Retención de copias</dt>
            <dd class="text-muted"><%= settings.backup_retention_days || 30 %> días</dd>
          </dl>
          <a href="/admin/settings" class="btn btn-sm btn-outline-secondary mt-2">
            <i class="bi bi-gear me-1"></i>Cambiar configuración
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent">
      <h3 class="h6 fw-semibold mb-0">Historial de copias</h3>
    </div>
    <% if (logs.length === 0) { %>
      <div class="card-body text-center text-muted py-4">
        <i class="bi bi-archive fs-2 opacity-50 mb-2 d-block"></i>
        Sin copias de seguridad. Crea la primera ahora.
      </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Archivo</th>
            <th>Tipo</th>
            <th>Tamaño</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(l => { %>
          <tr>
            <td class="small font-monospace"><%= l.filename %></td>
            <td>
              <span class="badge <%= l.type === 'manual' ? 'bg-primary' : l.type === 'weekly' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                <%= l.type %>
              </span>
            </td>
            <td class="small text-muted"><%= l.size ? Math.round(l.size / 1024) + ' KB' : '—' %></td>
            <td class="small text-muted"><%= new Date(l.created_at).toLocaleString('es-ES') %></td>
            <td><span class="badge <%= l.status === 'ok' ? 'bg-success' : 'bg-danger' %>"><%= l.status %></span></td>
            <td class="text-end">
              <a href="/admin/backups/download/<%= l.id %>" class="btn btn-xs btn-outline-primary me-1" title="Descargar">
                <i class="bi bi-download"></i>
              </a>
              <form method="POST" action="/admin/backups/restore/<%= l.id %>" class="d-inline"
                onsubmit="return confirm('⚠️ ATENCIÓN: Esto reemplazará toda la base de datos actual con esta copia de seguridad. ¿Continuar?')">
                <button type="submit" class="btn btn-xs btn-outline-warning" title="Restaurar">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
