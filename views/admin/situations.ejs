<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="page-content">
  <%- include('../partials/flash') %>
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-map me-2"></i>Situaciones de Aprendizaje</h1>
  </div>
  <div class="row g-4">
    <div class="col-lg-8">
      <% if (situations.length === 0) { %>
        <div class="card border-0 shadow-sm text-center py-5 text-muted">Sin situaciones creadas</div>
      <% } %>
      <% situations.forEach(s => { %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h3 class="h6 fw-bold mb-1"><%= s.title %></h3>
          <% if (s.description) { %><p class="small text-muted mb-2"><%= s.description %></p><% } %>
          <div class="d-flex flex-wrap gap-2 small">
            <% if (s.course) { %><span class="badge bg-primary-subtle text-primary"><i class="bi bi-mortarboard me-1"></i><%= s.course %></span><% } %>
            <% if (s.areas) { %><span class="badge bg-info-subtle text-info"><i class="bi bi-book me-1"></i><%= s.areas %></span><% } %>
            <% if (s.period) { %><span class="badge bg-warning-subtle text-warning"><i class="bi bi-calendar me-1"></i><%= s.period %></span><% } %>
          </div>
          <form method="POST" action="/admin/situations/<%= s.id %>/delete" class="mt-2" onsubmit="return confirm('¿Eliminar?')">
            <button type="submit" class="btn btn-xs btn-outline-danger"><i class="bi bi-trash me-1"></i>Eliminar</button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm sticky-top" style="top:20px">
        <div class="card-body">
          <h3 class="h6 fw-semibold mb-3">Nueva situación</h3>
          <form method="POST" action="/admin/situations">
            <div class="mb-2"><input type="text" name="title" class="form-control form-control-sm" placeholder="Título *" required></div>
            <div class="mb-2"><textarea name="description" class="form-control form-control-sm" rows="2" placeholder="Descripción"></textarea></div>
            <div class="mb-2"><input type="text" name="course" class="form-control form-control-sm" placeholder="Curso (ej: 3º)"></div>
            <div class="mb-2"><input type="text" name="areas" class="form-control form-control-sm" placeholder="Áreas (ej: Lengua, Matemáticas)"></div>
            <div class="mb-3"><input type="text" name="period" class="form-control form-control-sm" placeholder="Temporalización"></div>
            <button type="submit" class="btn btn-primary btn-sm w-100">Crear situación</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
