<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="page-content">
  <%- include('../partials/flash') %>
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-journal-bookmark me-2"></i>Programas</h1>
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <% programs.forEach(p => { %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <form method="POST" action="/admin/programs/<%= p.id %>">
            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="program-icon-lg" style="background:<%= p.color %>20; color:<%= p.color %>">
                <i class="bi bi-<%= p.icon %>"></i>
              </div>
              <div class="flex-grow-1">
                <input type="text" name="name" class="form-control form-control-sm fw-semibold" value="<%= p.name %>">
              </div>
              <input type="color" name="color" value="<%= p.color %>" class="form-control form-control-color" style="width:40px; height:36px">
              <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" name="active" id="active_<%= p.id %>" <%= p.active ? 'checked' : '' %>>
                <label class="form-check-label small" for="active_<%= p.id %>">Activo</label>
              </div>
            </div>
            <div class="row g-2">
              <div class="col-md-6">
                <input type="text" name="description" class="form-control form-control-sm" value="<%= p.description || '' %>" placeholder="Descripción">
              </div>
              <div class="col-md-3">
                <input type="text" name="icon" class="form-control form-control-sm" value="<%= p.icon || '' %>" placeholder="Icono Bootstrap">
              </div>
              <div class="col-md-3">
                <select name="mode" class="form-select form-select-sm">
                  <option value="individual" <%= (p.mode||'individual')==='individual'?'selected':'' %>>👤 Individual</option>
                  <option value="grupal"     <%= (p.mode||'')==='grupal'?'selected':'' %>>👥 Por grupos</option>
                </select>
              </div>
            </div>
            <div class="mt-2">
              <button type="submit" class="btn btn-sm btn-primary">Guardar</button>
            </div>
          </form>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h3 class="h6 fw-semibold mb-3">Nuevo programa</h3>
          <form method="POST" action="/admin/programs">
            <div class="mb-2">
              <input type="text" name="name" class="form-control form-control-sm" placeholder="Nombre *" required>
            </div>
            <div class="mb-2">
              <input type="text" name="description" class="form-control form-control-sm" placeholder="Descripción">
            </div>
            <div class="mb-2 d-flex gap-2">
              <input type="color" name="color" value="#0d6efd" class="form-control form-control-color" style="width:40px">
              <input type="text" name="icon" class="form-control form-control-sm" placeholder="Icono (ej: book)" value="book">
            </div>
            <div class="mb-2">
              <select name="mode" class="form-select form-select-sm">
                <option value="individual">👤 Individual (alumno a alumno)</option>
                <option value="grupal">👥 Por grupos (clase completa)</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm w-100">Añadir programa</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
