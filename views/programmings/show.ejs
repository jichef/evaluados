<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="page-content">
  <%- include('../partials/flash') %>

  <!-- Header -->
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/programmings" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h1 class="h4 fw-bold mb-0"><%= programming.name %></h1>
      <span class="badge border" style="background:<%=programming.color%>20;color:<%=programming.color%>">
        <i class="bi bi-journal-bookmark me-1"></i><%= programming.program_name %>
      </span>
      <% if (programming.course) { %>
      <span class="badge bg-info-subtle text-info border ms-1"><%= programming.course %></span>
      <% } %>
    </div>
    <form method="POST" action="/programmings/<%= programming.id %>/delete" class="ms-auto"
      onsubmit="return confirm('¿Eliminar esta programación y su secuencia?')">
      <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Eliminar</button>
    </form>
  </div>

  <div class="row g-4">

    <!-- Left col: settings + sequence -->
    <div class="col-lg-7">

      <!-- Settings -->
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-3">
          <form method="POST" action="/programmings/<%= programming.id %>">
            <div class="row g-2 align-items-end">
              <div class="col-sm">
                <label class="form-label form-label-sm fw-semibold mb-1">Nombre</label>
                <input type="text" name="name" class="form-control form-control-sm" value="<%= programming.name %>" required>
              </div>
              <div class="col-sm-auto">
                <label class="form-label form-label-sm fw-semibold mb-1">Programa</label>
                <select name="program_id" class="form-select form-select-sm">
                  <% programs.forEach(p => { %>
                  <option value="<%= p.id %>" <%= p.id === programming.program_id ? 'selected' : '' %>><%= p.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-sm-auto">
                <label class="form-label form-label-sm fw-semibold mb-1">Curso</label>
                <input type="text" name="course" class="form-control form-control-sm" style="width:110px"
                  value="<%= programming.course || '' %>" placeholder="Ej: 3º EP">
              </div>
              <div class="col-sm-auto d-flex align-items-center gap-2">
                <div class="form-check mb-0">
                  <input class="form-check-input" type="checkbox" name="active" id="chkActive" <%= programming.active ? 'checked' : '' %>>
                  <label class="form-check-label small" for="chkActive">Activa</label>
                </div>
                <button type="submit" class="btn btn-sm btn-primary">Guardar</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- Sequence -->
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-bottom-0 pt-3 pb-1">
          <h2 class="h6 fw-semibold mb-0"><i class="bi bi-list-ol me-2"></i>Secuencia de actividades
            <span class="badge bg-secondary-subtle text-secondary border ms-1"><%= activities.length %></span>
          </h2>
          <p class="small text-muted mb-0">El wizard mostrará la primera actividad pendiente de evaluar.</p>
        </div>
        <div class="list-group list-group-flush">
          <% if (!activities.length) { %>
          <div class="list-group-item text-center text-muted py-4">
            <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
            <p class="mb-0 small">Añade actividades desde el banco de la derecha.</p>
          </div>
          <% } %>
          <% activities.forEach((a, idx) => { %>
          <div class="list-group-item d-flex align-items-center gap-2 py-2">
            <span class="badge bg-light text-secondary border fw-normal" style="min-width:26px;text-align:center"><%= idx+1 %></span>
            <div class="flex-grow-1 small fw-semibold lh-sm"><%= a.name %></div>
            <span class="badge bg-light text-muted border" style="font-size:.65rem"><%= a.duration || 30 %> min</span>
            <!-- Move up -->
            <form method="POST" action="/programmings/<%= programming.id %>/activities/<%= a.pa_id %>/move" class="m-0">
              <input type="hidden" name="direction" value="up">
              <button type="submit" class="btn btn-xs btn-outline-secondary px-1 py-0" <%= idx===0?'disabled':'' %> title="Subir">
                <i class="bi bi-chevron-up"></i>
              </button>
            </form>
            <!-- Move down -->
            <form method="POST" action="/programmings/<%= programming.id %>/activities/<%= a.pa_id %>/move" class="m-0">
              <input type="hidden" name="direction" value="down">
              <button type="submit" class="btn btn-xs btn-outline-secondary px-1 py-0" <%= idx===activities.length-1?'disabled':'' %> title="Bajar">
                <i class="bi bi-chevron-down"></i>
              </button>
            </form>
            <!-- Remove -->
            <form method="POST" action="/programmings/<%= programming.id %>/activities/<%= a.pa_id %>/remove" class="m-0">
              <button type="submit" class="btn btn-xs btn-outline-danger px-1 py-0" title="Quitar">
                <i class="bi bi-x-lg"></i>
              </button>
            </form>
          </div>
          <% }) %>
        </div>
      </div>

    </div>

    <!-- Right col: activity bank -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm" style="position:sticky;top:1rem">
        <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
          <h2 class="h6 fw-semibold mb-2"><i class="bi bi-grid me-2"></i>Banco de actividades
            <span class="badge bg-secondary-subtle text-secondary border ms-1"><%= bankActivities.length %></span>
          </h2>
          <div class="input-group input-group-sm mb-2">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="bankSearch" class="form-control border-start-0 ps-1" placeholder="Buscar actividad...">
          </div>
        </div>
        <div class="card-body p-0" style="max-height:65vh;overflow-y:auto">
          <% if (!bankActivities.length) { %>
          <div class="p-3 text-muted small text-center">
            Este programa no tiene actividades. <a href="/activities">Crear actividades</a>
          </div>
          <% } %>
          <% bankActivities.forEach(a => { %>
          <form method="POST" action="/programmings/<%= programming.id %>/activities" class="bank-item m-0" data-name="<%= a.name.toLowerCase() %>">
            <input type="hidden" name="activity_id" value="<%= a.id %>">
            <button type="submit" class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2 px-3 border-0 w-100 text-start">
              <div class="flex-grow-1 small fw-semibold lh-sm"><%= a.name %></div>
              <span class="badge bg-light text-muted border" style="font-size:.65rem"><%= a.duration || 30 %> min</span>
              <i class="bi bi-plus-circle text-primary flex-shrink-0"></i>
            </button>
          </form>
          <% }) %>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
// Client-side bank search filter (show/hide only, no state)
const bankSearch = document.getElementById('bankSearch');
if (bankSearch) {
  bankSearch.addEventListener('input', function () {
    const q = this.value.toLowerCase().trim();
    document.querySelectorAll('.bank-item').forEach(function (el) {
      el.hidden = q !== '' && !el.dataset.name.includes(q);
    });
  });
}
</script>

<style>
.btn-xs { font-size: .75rem; line-height: 1.2; padding: .15rem .3rem; }
</style>

<%- include('../partials/footer') %>
